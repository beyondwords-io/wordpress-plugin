{
  "name": "beyondwords-wordpress-plugin",
  "version": "7.0.0-dev-1.0",
  "private": true,
  "description": "BeyondWords WordPress Plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/beyondwords-io/wordpress-plugin"
  },
  "author": "Stuart McAlpine <stu@beyondwords.io>",
  "license": "MIT",
  "homepage": "https://beyondwords.io",
  "main": "index.js",
  "devDependencies": {
    "@wordpress/api-fetch": "^7.44.0",
    "@wordpress/block-editor": "^15.17.0",
    "@wordpress/blocks": "^15.17.0",
    "@wordpress/components": "^32.6.0",
    "@wordpress/compose": "^7.44.0",
    "@wordpress/core-data": "^7.44.0",
    "@wordpress/data": "^10.44.0",
    "@wordpress/editor": "^14.44.0",
    "@wordpress/element": "^6.44.0",
    "@wordpress/env": "^11.4.0",
    "@wordpress/eslint-plugin": "^25.0.0",
    "@wordpress/hooks": "^4.44.0",
    "@wordpress/html-entities": "^4.44.0",
    "@wordpress/i18n": "^6.17.0",
    "@wordpress/notices": "^5.44.0",
    "@wordpress/plugins": "^7.44.0",
    "@wordpress/scripts": "^32.0.0",
    "badge-maker": "^5.0.2",
    "cypress": "^15.14.0",
    "cypress-fail-fast": "^8.1.0",
    "cypress-map": "^1.56.0",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-terminal-report": "^7.3.3",
    "dotenv": "^17.4.2",
    "lodash": "^4.18.1",
    "mochawesome": "^7.1.4",
    "uuid": "^14.0.0"
  },
  "scripts": {
    "build": "wp-scripts build",
    "check-engines": "wp-scripts check-engines",
    "check-licenses": "wp-scripts check-licenses",
    "composer": "wp-env run cli --env-cwd=/var/www/html/wp-content/plugins/speechkit composer",
    "cypress:open": "cypress open --e2e --browser chrome",
    "cypress:run": "ELECTRON_RUN_AS_NODE= cypress run",
    "cypress:setup": "node tests/cypress/scripts/setup-ci.js",
    "format": "wp-scripts format",
    "format:src": "wp-scripts format ./src",
    "grumphp": "wp-env run cli --env-cwd=/var/www/html/wp-content/plugins/speechkit ./vendor/bin/grumphp",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js ./src",
    "lint:md:docs": "wp-scripts lint-md-docs",
    "lint:md:js": "wp-scripts lint-md-js",
    "lint:pkg-json": "wp-scripts lint-pkg-json",
    "packages-update": "wp-scripts packages-update",
    "phpcs": "wp-env run cli --env-cwd=/var/www/html/wp-content/plugins/speechkit ./vendor/bin/phpcs -d memory_limit=512M",
    "phpcs:plugins": "wp-env run cli --env-cwd=/var/www/html/wp-content/plugins/speechkit ./vendor/bin/phpcs --standard=plugins/.phpcs.xml plugins/",
    "phpcbf": "wp-env run cli --env-cwd=/var/www/html/wp-content/plugins/speechkit ./vendor/bin/phpcbf -d memory_limit=512M",
    "rector": "wp-env run cli --env-cwd=/var/www/html/wp-content/plugins/speechkit ./vendor/bin/rector process --dry-run",
    "rector:fix": "wp-env run cli --env-cwd=/var/www/html/wp-content/plugins/speechkit ./vendor/bin/rector process",
    "rector:fix:diff": "wp-env run cli --env-cwd=/var/www/html/wp-content/plugins/speechkit ./vendor/bin/rector process --debug",
    "start": "wp-scripts start",
    "test:e2e": "wp-scripts test-e2e",
    "test:unit": "wp-scripts test-unit-js",
    "test:phpunit": "wp-env run tests-cli --env-cwd=wp-content/plugins/speechkit ./vendor/bin/phpunit",
    "wp-cli:plugin-check": "wp-env run cli wp plugin check speechkit",
    "wp-env": "wp-env",
    "wp-env:start": "wp-env start --xdebug=debug,coverage --update"
  }
}
