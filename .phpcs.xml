<?xml version="1.0"?>
<ruleset name="BeyondWords WordPress Plugin">
	<description>WordPress VIP coding standards for the BeyondWords WordPress plugin.</description>

	<!-- What to scan -->
	<file>src</file>
	<file>speechkit.php</file>
	<file>uninstall.php</file>
	<file>index.php</file>

	<!-- How to scan -->
	<arg value="sp"/>
	<arg name="basepath" value="./"/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>
	<ini name="error_reporting" value="E_ALL &#38; ~E_DEPRECATED"/>

	<!-- WordPress VIP Go -->
	<rule ref="WordPress-VIP-Go"/>

	<!-- Always use short array syntax: [] not array() -->
	<rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

	<!-- The legacy code under src/ (excluding src/settings/) predates this ruleset; relax until migrated. -->
	<rule ref="WordPress.WP.CapitalPDangit.MisspelledNamespaceName">
		<severity>0</severity>
	</rule>
	<rule ref="Squiz.Commenting.FileComment">
		<severity>0</severity>
	</rule>
	<rule ref="Generic.Commenting.DocComment.MissingShort">
		<severity>0</severity>
	</rule>
	<rule ref="WordPress.PHP.YodaConditions.NotYoda">
		<severity>0</severity>
	</rule>

	<!-- BeyondWords text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="speechkit"/>
			</property>
		</properties>
	</rule>
</ruleset>
